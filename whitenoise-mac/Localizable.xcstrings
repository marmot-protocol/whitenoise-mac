    "Archived groups are hidden from the active chat list." : {

    },
    "Archiving hides the group from your main chats list. It doesn't change your membership or notify anyone." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Durch die Archivierung wird die Gruppe aus Ihrer Hauptchatliste ausgeblendet. Es ändert nichts an Ihrer Mitgliedschaft und benachrichtigt niemanden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Archivar oculta el grupo de su lista principal de chats. No cambia su membresía ni notifica a nadie."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'archivage masque le groupe de votre liste de discussions principale. Cela ne modifie pas votre adhésion et n’en informe personne."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'archiviazione nasconde il gruppo dall'elenco delle chat principali. Non modifica la tua iscrizione né avvisa nessuno."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O arquivamento oculta o grupo da sua lista principal de bate-papos. Isso não altera sua associação nem notifica ninguém."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При архивировании группа скрывается из основного списка чатов. Это не меняет ваше членство и не уведомляет кого-либо."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arşivleme, grubu ana sohbet listenizden gizler. Üyeliğinizi değiştirmez veya kimseye bildirimde bulunmaz."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "存档会在主聊天列表中隐藏该组。它不会更改您的会员资格或通知任何人。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "存檔會在主聊天清單中隱藏該群組。它不會更改您的會員資格或通知任何人。"
          }
        }
      }
    },
