    "Paste your nsec (bech32 secret key). Public npub values are for sharing and cannot sign in." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügen Sie Ihren nsec (bech32-Geheimschlüssel) ein. Öffentliche npub-Werte dienen der Freigabe und können nicht angemeldet werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pegue su nsec (clave secreta de bech32). Los valores públicos npub son para compartir y no pueden iniciar sesión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Collez votre nsec (clé secrète bech32). Les valeurs publiques npub sont destinées au partage et ne permettent pas de se connecter."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
