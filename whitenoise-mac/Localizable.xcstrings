            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "%@ hasn't published a compatible key package yet." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hat noch kein kompatibles Schlüsselpaket veröffentlicht."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ aún no ha publicado un paquete de claves compatible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ n’a pas encore publié de package de clé compatible."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non ha ancora pubblicato un pacchetto di chiavi compatibile."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ ainda não publicou um pacote de chaves compatível."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ еще не опубликовал совместимый пакет ключей."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ henüz uyumlu bir anahtar paketi yayınlamadı."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@尚未发布兼容的密钥包。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@尚未發布相容的金鑰包。"
          }
        }
      }
    },
    "%@ hasn't published a compatible key package, so they can't be added yet." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hat kein kompatibles Schlüsselpaket veröffentlicht und kann daher noch nicht hinzugefügt werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ no ha publicado un paquete de claves compatibles, por lo que no se pueden agregar todavía."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ n’a pas publié de package de clés compatible, il ne peut donc pas encore être ajouté."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non ha pubblicato un pacchetto di chiavi compatibile, quindi non è ancora possibile aggiungerlo."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ não publicou um pacote de chaves compatível, portanto eles ainda não podem ser adicionados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не опубликовал совместимый пакет ключей, поэтому его пока нельзя добавить."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ uyumlu bir anahtar paketi yayınlamadığından henüz eklenemiyor."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@尚未发布兼容的密钥包，因此尚无法添加。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@尚未發布相容的金鑰包，因此尚無法新增。"
          }
        }
      }
    },
    "%@ hasn't published a compatible key package, so they can't be messaged yet." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hat kein kompatibles Schlüsselpaket veröffentlicht, daher können noch keine Nachrichten gesendet werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ no ha publicado un paquete de claves compatible, por lo que aún no se les puede enviar mensajes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ n’a pas publié de package de clés compatible, vous ne pouvez donc pas encore leur envoyer de message."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ non ha pubblicato un pacchetto di chiavi compatibile, quindi non è ancora possibile inviare messaggi."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ não publicou um pacote de chaves compatível, então eles ainda não podem receber mensagens."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ не опубликовал совместимый пакет ключей, поэтому их пока невозможно отправить."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ uyumlu bir anahtar paketi yayınlamadığından henüz mesaj gönderilemiyor."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 尚未发布兼容的密钥包，因此还无法向他们发送消息。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 尚未發布相容的金鑰包，因此無法向他們發送訊息。"
          }
        }
      }
    },
